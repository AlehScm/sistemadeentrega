PORT=4000

# Pooler (Supavisor) — porta 6543, uso em runtime com ?pgbouncer=true
# Substitua [user], [password], [host] pelos valores do painel Supabase (Database → Connect).
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true"

# Conexão direta — migrations e prisma db push (mesmo host, porta 5432)
DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres"
